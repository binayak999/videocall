## Frontend environment variables (Vite)
#
# Dev proxy target for local API (default in vite.config is http://localhost:4001).
# The browser calls /api/* on the Vite dev server; Vite proxies to this target.
# Use https://… only if your API actually serves TLS (set secure: false in vite for self-signed).
#
# Vite only exposes variables prefixed with VITE_ to the browser.

# Minimum age for the in-app date-of-birth gate (self-attestation only).
# VITE_MINIMUM_AGE=18

# Set to "false" to disable periodic NSFW classification on the local camera during calls (dev / debugging).
# VITE_CAMERA_MODERATION=false

# VITE_API_PROXY_TARGET=http://localhost:4001

# Optional: Companion bridge base URL for remote-control forwarding.
# Default is http://127.0.0.1:7830 (same-device browser + companion).
# For phone -> desktop control, set this to your desktop LAN IP, e.g.:
# VITE_COMPANION_BRIDGE_URL=http://192.168.1.42:7830

# Optional: override STUN servers (comma-separated URLs)
# Example:
# VITE_ICE_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# Optional: TURN fallback for restrictive/corporate networks
# Provide all three values together (comma-separated TURN URLs + credentials)
# Example:
# VITE_ICE_TURN_URLS=turn:turn.example.com:3478,turns:turn.example.com:5349?transport=tcp
# VITE_ICE_TURN_USERNAME=example-user
# VITE_ICE_TURN_CREDENTIAL=example-password

# TURN credentials API (server-side, not exposed to browser by Vite)
TURN_SECRET=
TURN_HOST=

