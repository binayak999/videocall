# Copy to apps/api/.env. The API loads this file from the apps/api working directory (yarn workspace api dev).
# Repo-root server/.env is used for some Prisma commands; R2 vars must still be in apps/api/.env for recordings.
# Never commit real secrets.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/meetclone"
JWT_SECRET="change-me"

# Cloudflare R2 — recordings use the S3 API (PutObject). Use this host, not a public CDN-only domain:
# R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Or leave R2_ENDPOINT empty and set R2_ACCOUNT_ID (same URL is built automatically).
R2_ENDPOINT=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Path-style https://endpoint/bucket/key (recommended for R2).
R2_FORCE_PATH_STYLE=true
# R2_FORCE_PATH_STYLE=false

# Public URL for playback only (optional). If unset, list/detail use signed GET URLs.
# R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev
