# Copy to apps/api/.env. The API loads this file from the apps/api working directory (yarn workspace api dev).
# Repo-root server/.env is used for some Prisma commands; R2 vars must still be in apps/api/.env for recordings.
# Never commit real secrets.

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/meetclone"
JWT_SECRET="change-me"

# Google Sign-In (verify ID tokens from the SPA). Must match client VITE_GOOGLE_CLIENT_ID exactly.
# Same Client ID from Google Cloud Console → Credentials → OAuth 2.0 Client IDs → Web application.
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com

# reCAPTCHA v3 (optional in dev: omit RECAPTCHA_SECRET_KEY to skip server verification).
# RECAPTCHA_SECRET_KEY=
# Optional; default 0.5
# RECAPTCHA_MIN_SCORE=0.5

# LiveKit (SFU) — token minting + room join (self-hosted). Example:
# LIVEKIT_URL=wss://livekit.example.com
# LIVEKIT_API_KEY=LKxxxxxx
# LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare R2 — recordings use the S3 API (PutObject). Use this host, not a public CDN-only domain:
# R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Or leave R2_ENDPOINT empty and set R2_ACCOUNT_ID (same URL is built automatically).
R2_ENDPOINT=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Path-style https://endpoint/bucket/key (recommended for R2).
R2_FORCE_PATH_STYLE=true
# R2_FORCE_PATH_STYLE=false

# Public URL for playback only (optional). If unset, list/detail use signed GET URLs.
# R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev

# Host-only agenda check: POST /api/meetings/:code/agenda/analyze
# Prefer Hugging Face Inference (OpenAI-compatible router). Fine-grained token with "Make calls to Inference Providers":
# https://huggingface.co/settings/tokens
# HUGGINGFACE_API_TOKEN=hf_...
# Alias: HF_TOKEN
# Default model (override if needed): google/gemma-2-2b-it
# HF_AGENDA_MODEL=google/gemma-2-2b-it
# Base URL (default https://router.huggingface.co/v1)
# HF_INFERENCE_BASE_URL=https://router.huggingface.co/v1
# If the model errors on JSON mode, disable strict json_object (default on):
# HF_AGENDA_JSON_MODE=0

# Fallback: OpenAI
# OPENAI_API_KEY=
# OPENAI_AGENDA_MODEL=gpt-4o-mini

# POST /api/translate — same keys as above; optional dedicated models:
# HF_TRANSLATE_MODEL=google/gemma-2-2b-it
# OPENAI_TRANSLATE_MODEL=gpt-4o-mini
