generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String?
  provider  String
  createdAt DateTime @default(now())

  hostedMeetings Meeting[]           @relation("MeetingHost")
  participants   Participant[]
  recordings     MeetingRecording[]
}

model Meeting {
  id        String    @id @default(cuid())
  code      String    @unique
  hostId    String
  host      User      @relation("MeetingHost", fields: [hostId], references: [id])
  title     String?
  createdAt DateTime  @default(now())
  endsAt    DateTime?

  participants Participant[]
  chatMessages ChatMessage[]
  captions     MeetingCaption[]
  recordings   MeetingRecording[]
  polls        MeetingPoll[]
}

model MeetingPoll {
  id          String    @id @default(cuid())
  meetingId   String
  meeting     Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  title       String
  anonymous   Boolean
  createdAt   DateTime  @default(now())
  endedAt     DateTime?

  votes MeetingPollVote[]

  @@index([meetingId, createdAt])
}

model MeetingPollVote {
  id          String      @id @default(cuid())
  pollId      String
  poll        MeetingPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  voterUserId String
  voterName   String
  choice      String
  updatedAt   DateTime    @updatedAt

  @@unique([pollId, voterUserId])
}

model MeetingRecording {
  id          String   @id @default(cuid())
  meetingId   String
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  hostId      String
  host        User     @relation(fields: [hostId], references: [id])
  r2Key       String   @unique
  mimeType    String   @default("video/webm")
  durationSec Int?
  sizeBytes   Int?
  createdAt   DateTime @default(now())

  @@index([hostId, createdAt])
  @@index([meetingId])
}

model Participant {
  id        String    @id @default(cuid())
  meetingId String
  meeting   Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?     @relation(fields: [userId], references: [id])
  guestName String?
  role      String
  joinedAt  DateTime  @default(now())
  leftAt    DateTime?
}

model ChatMessage {
  id           String   @id @default(cuid())
  meetingId    String
  meeting      Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  senderUserId String
  senderName   String
  text         String
  createdAt    DateTime @default(now())

  @@index([meetingId, createdAt])
}

model MeetingCaption {
  id            String   @id @default(cuid())
  meetingId     String
  meeting       Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  speakerUserId String
  speakerName   String
  text          String
  createdAt     DateTime @default(now())

  @@index([meetingId, createdAt])
}
