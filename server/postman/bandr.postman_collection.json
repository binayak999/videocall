    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    try {",
                  "        var j = pm.response.json();",
                  "        if (j.token) { pm.collectionVariables.set('token', j.token); }",
                  "    } catch (e) {}",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo@example.com\",\n  \"password\": \"password12\",\n  \"name\": \"Demo User\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register",
            "description": "Creates user and returns JWT. Test script saves `token` to collection variables."
