    {
      "name": "Meetings",
      "item": [
        {
          "name": "POST /api/meetings (Bearer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    try {",
                  "        var j = pm.response.json();",
                  "        if (j.meeting && j.meeting.code) {",
                  "            pm.collectionVariables.set('meetingCode', j.meeting.code);",
                  "        }",
                  "    } catch (e) {}",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My meeting\"\n}"
            },
            "url": "{{baseUrl}}/api/meetings",
            "description": "Requires `token`. Saves `meeting.code` to `meetingCode` on success."
