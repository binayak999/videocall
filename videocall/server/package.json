{
  "name": "nexivo",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "start": "turbo run start --filter=api --filter=signaling",
    "dev": "turbo run dev",
    "db:generate": "yarn workspace @bandr/db db:generate",
    "db:migrate": "yarn workspace @bandr/db db:migrate",
    "db:migrate:deploy": "yarn workspace @bandr/db db:migrate:deploy",
    "postinstall": "yarn workspace @bandr/db db:generate"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
