# Copy to `.env` in this folder. Restart Expo (`npx expo start -c`) after edits.
# Web client: VITE_* → Mobile: EXPO_PUBLIC_* (same values).

EXPO_PUBLIC_API_BASE=https://video.upliftsolutions.com.np

# Optional; defaults to EXPO_PUBLIC_API_BASE if unset.
# EXPO_PUBLIC_SIGNALING_URL=https://video.upliftsolutions.com.np

# reCAPTCHA v3 site key (public) — same as VITE_RECAPTCHA_SITE_KEY on web.
EXPO_PUBLIC_RECAPTCHA_SITE_KEY=

# Optional. Page origin for WebView reCAPTCHA (must be listed in Google reCAPTCHA admin).
# Defaults to EXPO_PUBLIC_API_BASE. Set if your API host differs from the domain allowed for the key.
# EXPO_PUBLIC_RECAPTCHA_BASE_URL=https://video.upliftsolutions.com.np
